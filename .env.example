# Pico provider settings
# Configuration precedence: CLI flags > PICO_* variables > provider defaults.

PICO_PROVIDER=fake

# Ollama
PICO_OLLAMA_HOST=http://localhost:11434
PICO_OLLAMA_MODEL=qwen2.5-coder

# OpenAI-compatible chat completions
PICO_OPENAI_API_BASE=https://api.openai.com
PICO_OPENAI_API_KEY=
PICO_OPENAI_MODEL=gpt-4.1

# Anthropic-compatible Messages API
PICO_ANTHROPIC_API_BASE=https://api.anthropic.com
PICO_ANTHROPIC_API_KEY=
PICO_ANTHROPIC_MODEL=claude-opus-4-8

# Comma-separated env var names that should be treated as secrets in traces/reports.
PICO_SECRET_ENV_NAMES=
